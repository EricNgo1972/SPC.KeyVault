@inject NavigationManager NavigationManager

@code {
    protected override void OnInitialized()
    {
        var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        if (path.StartsWith("ui/login", StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var returnUrl = "/" + path;
        NavigationManager.NavigateTo($"/ui/login?returnUrl={Uri.EscapeDataString(returnUrl)}", forceLoad: true);
    }
}
