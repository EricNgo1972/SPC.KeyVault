@page "/ui"
@page "/ui/secrets"
@attribute [Authorize(Policy = "SpcAdmin")]
@layout MainLayout
@inject SecretStore SecretStore

<PageTitle>Secrets</PageTitle>

<div class="page">
<div class="page-head">
    <div>
        <h2>Secrets</h2>
        <p class="muted">Browse, create, and update secrets across all categories. The empty category is shown as <b>Default</b>.</p>
    </div>

    <button class="button primary" @onclick="CreateSecret">New secret</button>
</div>

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert">@ErrorMessage</div>
}

@if (SecretItems.Count == 0)
{
    <div class="empty-state">No secrets found.</div>
}
else
{
    <div class="table-shell">
        <table>
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Name</th>
                    <th>Value</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var secret in SecretItems)
                {
                    var revealKey = GetRevealKey(secret);
                    var isRevealed = RevealedSecrets.Contains(revealKey);

                    <tr>
                        <td>@FormatCategory(secret.Category)</td>
                        <td>@secret.Name</td>
                        <td class="value-cell">
                            <code>@(isRevealed ? secret.Value : MaskValue(secret.Value))</code>
                            <button class="button secondary compact" @onclick="() => ToggleRowReveal(revealKey)">@(isRevealed ? "Hide" : "Reveal")</button>
                        </td>
                        <td>
                            <button class="button secondary compact" @onclick="() => EditSecret(secret)">Edit</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (IsModalOpen)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-card" @onclick:stopPropagation="true">
            <div class="modal-head">
                <h3>@(IsEditing ? "Edit secret" : "New secret")</h3>
                <button class="button secondary compact" @onclick="CloseModal">Close</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(ModalErrorMessage))
            {
                <div class="alert">@ModalErrorMessage</div>
            }

            <EditForm Model="EditModel" OnValidSubmit="SaveSecretAsync">
                <div class="form-grid">
                    <label>
                        <span>Category</span>
                        <InputText @bind-Value="EditModel.Category" placeholder="Default" />
                    </label>

                    <label>
                        <span>Name</span>
                        <InputText @bind-Value="EditModel.Name" disabled="@IsEditing" />
                    </label>

                    <label>
                        <span>Value</span>
                        <div class="value-input">
                            <InputText @bind-Value="EditModel.Value" type="@(IsEditValueRevealed ? "text" : "password")" />
                            <button type="button" class="button secondary compact" @onclick="ToggleModalReveal">@(IsEditValueRevealed ? "Hide" : "Reveal")</button>
                        </div>
                    </label>
                </div>

                @if (IsEditing)
                {
                    <p class="hint">Name and category stay fixed in this first UI version. Update the value only.</p>
                }

                <div class="modal-actions">
                    <button type="button" class="button secondary" @onclick="CloseModal">Cancel</button>
                    <button type="submit" class="button primary">Save</button>
                </div>
            </EditForm>
        </div>
    </div>
}
</div>

@code {
    private readonly HashSet<string> RevealedSecrets = new(StringComparer.Ordinal);
    private List<SecretListItem> SecretItems { get; set; } = [];
    private bool IsModalOpen { get; set; }
    private bool IsEditing { get; set; }
    private bool IsEditValueRevealed { get; set; }
    private string? ErrorMessage { get; set; }
    private string? ModalErrorMessage { get; set; }
    private SecretEditorModel EditModel { get; set; } = new();

    protected override void OnInitialized()
    {
        LoadSecrets();
    }

    private void LoadSecrets()
    {
        var result = SecretStore.ListAll();
        if (!result.IsAvailable)
        {
            ErrorMessage = result.Error;
            SecretItems = [];
            return;
        }

        ErrorMessage = null;
        SecretItems = result.Secrets.ToList();
    }

    private void CreateSecret()
    {
        IsEditing = false;
        IsModalOpen = true;
        IsEditValueRevealed = false;
        ModalErrorMessage = null;
        EditModel = new SecretEditorModel();
    }

    private void EditSecret(SecretListItem secret)
    {
        IsEditing = true;
        IsModalOpen = true;
        IsEditValueRevealed = false;
        ModalErrorMessage = null;
        EditModel = new SecretEditorModel
        {
            Category = secret.Category,
            Name = secret.Name,
            Value = secret.Value
        };
    }

    private Task SaveSecretAsync()
    {
        if (string.IsNullOrWhiteSpace(EditModel.Name))
        {
            ModalErrorMessage = "Name is required.";
            return Task.CompletedTask;
        }

        var writeResult = SecretStore.SetMany(
            NormalizeCategory(EditModel.Category),
            [new KeyValuePair<string, string>(EditModel.Name.Trim(), EditModel.Value ?? string.Empty)]);

        if (!writeResult.Succeeded)
        {
            ModalErrorMessage = writeResult.Error;
            return Task.CompletedTask;
        }

        CloseModal();
        LoadSecrets();
        return Task.CompletedTask;
    }

    private void CloseModal()
    {
        IsModalOpen = false;
        IsEditValueRevealed = false;
        ModalErrorMessage = null;
    }

    private void ToggleRowReveal(string revealKey)
    {
        if (!RevealedSecrets.Add(revealKey))
        {
            RevealedSecrets.Remove(revealKey);
        }
    }

    private void ToggleModalReveal()
    {
        IsEditValueRevealed = !IsEditValueRevealed;
    }

    private static string NormalizeCategory(string? category)
    {
        return string.IsNullOrWhiteSpace(category) ? string.Empty : category.Trim();
    }

    private static string FormatCategory(string category)
    {
        return string.IsNullOrWhiteSpace(category) ? "Default" : category;
    }

    private static string MaskValue(string? value)
    {
        if (string.IsNullOrEmpty(value))
        {
            return "(empty)";
        }

        return new string('•', Math.Min(value.Length, 12));
    }

    private static string GetRevealKey(SecretListItem secret)
    {
        return $"{secret.Category}|{secret.Name}";
    }

    private sealed class SecretEditorModel
    {
        public string Category { get; set; } = string.Empty;

        public string Name { get; set; } = string.Empty;

        public string Value { get; set; } = string.Empty;
    }
}
